{% set heroImg = heroImage or site.hero.image or 'hero.jpg' %}
{% set heroPath = "src/assets/images/hero/" ~ heroImg %}

<section class="hero-full">
  {% image heroPath, site.hero.title, "hero_image", "eager" %}
  <div class="hero-full__content">
    <h1 class="hero-full__title">{{ site.hero.title }}</h1>
    <p class="hero-full__subtitle">{{ site.hero.subtitle }}</p>
    <div class="hero-full__actions">
      <a href="#presupuesto" class="hero-full__btn hero-full__btn--primary">Presupuesto gratis</a>
      <a href="/contacto/" class="hero-full__btn hero-full__btn--outline">Contactenos</a>
    </div>
  </div>
</section>
