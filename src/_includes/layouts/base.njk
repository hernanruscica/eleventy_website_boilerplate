<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">

  <title>{% if title %}{{ title }} — {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">

  <link rel="preload" href="/assets/fonts/mulish-latin.woff2" as="font" type="font/woff2" crossorigin>

  <style>{% criticalCss %}</style>
</head>
<body>

  <a href="#main-content" class="skip-nav">Saltar al contenido principal</a>

  <header class="site-header">
    <nav class="main-nav" aria-label="Navegación principal">
      <a href="/" class="main-nav__brand">
        <img src="/assets/images/logo.svg" alt="" class="main-nav__logo" width="36" height="36">
        <span class="main-nav__site-name">{{ site.name }}</span>
      </a>
      <button class="main-nav__toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Abrir menú">
        <span class="main-nav__hamburger"></span>
      </button>
      <ul id="nav-menu" class="main-nav__menu">
        {% for item in site.nav %}
        <li><a href="{{ item.url }}" {% if page.url === item.url %}aria-current="page"{% endif %}>{{ item.text }}</a></li>
        {% endfor %}
      </ul>
    </nav>
  </header>

  <main id="main-content" tabindex="-1">
    {{ content | safe }}
  </main>

  <footer>
    <div class="footer-content">
      <p>&copy; {{ site.name }} — Todos los derechos reservados.</p>
      <div class="social-links">
        <a href="#" aria-label="LinkedIn" rel="noopener noreferrer">{% include "icons/linkedin.njk" %}</a>
        <a href="#" aria-label="GitHub" rel="noopener noreferrer">{% include "icons/github.njk" %}</a>
        <a href="#" aria-label="Twitter / X" rel="noopener noreferrer">{% include "icons/twitter.njk" %}</a>
        <a href="mailto:hola@ejemplo.com" aria-label="Correo electrónico">{% include "icons/email.njk" %}</a>
      </div>
    </div>
    <button id="btn-top" class="btn-top" aria-label="Volver al inicio">
      <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>
  </footer>

  {% jsTag "main.js" %}
  {% if scripts and scripts.includes('form') %}
  {% jsTag "form.js" %}
  {% endif %}
  {% if scripts and scripts.includes('blog') %}
  {% jsTag "blog.js" %}
  {% endif %}

</body>
</html>
